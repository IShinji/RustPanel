GITHUB_REPOSITORY_URL=https://github.com/IShinji/RustPanel
GITHUB_RUNNER_TOKEN=paste-registration-token-here
GITHUB_RUNNER_NAME=Shinji-M4-RustPanel
GITHUB_RUNNER_LABELS=m4-runner,rustpanel-runner
GITHUB_RUNNER_WORKDIR=_work

# OrbStack:
DOCKER_SOCKET=/Users/wisely/.orbstack/run/docker.sock

# Docker Desktop 通常可改为：
# DOCKER_SOCKET=/var/run/docker.sock

# 与 Dockerfile 保持一致；升级 runner 时同时改 Dockerfile/compose/docs。
RUNNER_VERSION=2.334.0
