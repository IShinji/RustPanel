COMPOSE_PROJECT_NAME=rustpanel
BACKEND_IMAGE=ghcr.io/ishinji/rustpanel-backend:latest
RUSTPANEL_INSTALL_DIR=/www/wwwroot/rustpanel
RUSTPANEL_DATA_DIR=/www/wwwroot/rustpanel/data
RUSTPANEL_BIND_HOST=127.0.0.1
RUSTPANEL_API_PORT=18080
RUSTPANEL_ALLOWED_ORIGINS=https://rustpanel.icanghai.com
RUSTPANEL_ADMIN_USERNAME=admin
RUSTPANEL_ADMIN_PASSWORD=replace-with-a-random-password
RUSTPANEL_JWT_SECRET=replace-with-at-least-32-random-bytes
GITHUB_TOKEN=
GHCR_USERNAME=
